generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RewriteStatus {
  pending
  published
  needs_retry
  failed
  skipped
}

enum FeedVisibilityStatus {
  published
  hidden
}

enum JobStatus {
  started
  success
  failed
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@map("users")
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  tokenHash String?   @map("token_hash")
  expiresAt DateTime? @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("invites")
}

model SourceNotice {
  messageId      Int       @id @map("message_id")
  newsId         Int       @map("news_id")
  title          String
  issuerName     String    @map("issuer_name")
  issuerSign     String    @map("issuer_sign")
  publishedAt    DateTime  @map("published_at")
  categoriesJson Json      @map("categories_json")
  marketsJson    Json      @map("markets_json")
  bodyText       String    @map("body_text") @db.Text
  hasAttachments Boolean   @map("has_attachments")
  rawMessageJson Json      @map("raw_message_json")
  ingestedAt     DateTime  @default(now()) @map("ingested_at")
  rewrites       Rewrite[]
  feedItem       FeedItem?
  jobRuns        JobRun[]

  @@index([publishedAt(sort: Desc)])
  @@index([issuerSign])
  @@index([categoriesJson], type: Gin)
  @@map("source_notices")
}

model Rewrite {
  id              String        @id @default(cuid())
  messageId       Int           @map("message_id")
  version         Int           @default(1)
  lang            String
  model           String
  promptVersion   String        @map("prompt_version")
  rewriteJson     Json          @map("rewrite_json")
  validationJson  Json          @map("validation_json")
  status          RewriteStatus
  userInstruction String?       @map("user_instruction") @db.Text
  generatedAt     DateTime      @default(now()) @map("generated_at")
  sourceNotice    SourceNotice  @relation(fields: [messageId], references: [messageId], onDelete: Cascade)

  @@unique([messageId, version])
  @@index([status, generatedAt(sort: Desc)])
  @@map("rewrites")
}

model FeedItem {
  messageId        Int                 @id @map("message_id")
  publishedAt      DateTime            @map("published_at")
  visibilityStatus FeedVisibilityStatus @default(published) @map("visibility_status")
  rankScore        Float               @default(0) @map("rank_score")
  sourceNotice     SourceNotice        @relation(fields: [messageId], references: [messageId], onDelete: Cascade)

  @@index([publishedAt(sort: Desc), visibilityStatus])
  @@map("feed_items")
}

model JobRun {
  id          String      @id @default(cuid())
  jobType     String      @map("job_type")
  messageId   Int?        @map("message_id")
  status      JobStatus
  startedAt   DateTime    @default(now()) @map("started_at")
  finishedAt  DateTime?   @map("finished_at")
  errorText   String?     @map("error_text") @db.Text
  sourceNotice SourceNotice? @relation(fields: [messageId], references: [messageId], onDelete: SetNull)

  @@index([jobType, startedAt(sort: Desc)])
  @@map("job_runs")
}

model GenerationRun {
  id                  String       @id @default(cuid())
  messageId           Int          @map("message_id")
  version             Int?
  jobId               String?      @map("job_id")
  jobName             String?      @map("job_name")
  reason              String
  status              String
  userInstruction     String?      @map("user_instruction") @db.Text
  inputJson           Json?        @map("input_json")
  previousRewriteJson Json?        @map("previous_rewrite_json")
  outputJson          Json?        @map("output_json")
  validationJson      Json?        @map("validation_json")
  model               String?
  promptVersion       String?      @map("prompt_version")
  promptChars         Int?         @map("prompt_chars")
  errorText           String?      @map("error_text") @db.Text
  requestedAt         DateTime     @default(now()) @map("requested_at")
  startedAt           DateTime?    @map("started_at")
  finishedAt          DateTime?    @map("finished_at")

  @@index([messageId, requestedAt(sort: Desc)])
  @@index([jobId])
  @@index([status, requestedAt(sort: Desc)])
  @@map("generation_runs")
}

model UserActionEvent {
  id            String   @id @default(cuid())
  messageId     Int?     @map("message_id")
  version       Int?
  clientEventId String?  @map("client_event_id")
  editorIdHash  String?  @map("editor_id_hash")
  sessionIdHash String?  @map("session_id_hash")
  rewriteId     String?  @map("rewrite_id")
  promptVersion String?  @map("prompt_version")
  model         String?
  action        String
  actionSource  String?  @map("action_source")
  payloadJson   Json?    @map("payload_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([messageId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([clientEventId])
  @@index([editorIdHash, createdAt(sort: Desc)])
  @@index([sessionIdHash, createdAt(sort: Desc)])
  @@index([rewriteId, createdAt(sort: Desc)])
  @@map("user_action_events")
}

model EditLog {
  id              String   @id @default(cuid())
  eventId         String?  @map("event_id")
  messageId       Int      @map("message_id")
  originalTitle   String   @map("original_title")
  originalBody    String   @map("original_body") @db.Text
  editedTitle     String   @map("edited_title")
  editedBody      String   @map("edited_body") @db.Text
  hasEdits        Boolean  @map("has_edits")
  copiedAt        DateTime @default(now()) @map("copied_at")

  @@index([messageId, copiedAt(sort: Desc)])
  @@index([eventId])
  @@map("edit_logs")
}

model Feedback {
  id        String   @id @default(cuid())
  eventId   String?  @map("event_id")
  messageId Int      @map("message_id")
  version   Int?
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([messageId, createdAt(sort: Desc)])
  @@index([eventId])
  @@map("feedback")
}

model TitleSuggestionLog {
  id              String   @id @default(cuid())
  eventId         String?  @map("event_id")
  messageId       Int      @map("message_id")
  currentTitle    String   @map("current_title")
  suggestions     Json     @map("suggestions")
  selectedTitle   String?  @map("selected_title")
  action          String?
  selectedIndex   Int?     @map("selected_index")
  selectedWasOriginal Boolean? @map("selected_was_original")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([messageId, createdAt(sort: Desc)])
  @@index([eventId])
  @@map("title_suggestion_logs")
}
